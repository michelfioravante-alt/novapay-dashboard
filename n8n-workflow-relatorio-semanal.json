    {
      "parameters": {
        "method": "POST",
        "url": "https://rxtnlvzxhzyeetpobkyx.supabase.co/rest/v1/rpc/gerar_relatorio_semanal",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
